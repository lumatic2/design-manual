import { test, expect } from '@playwright/test';

/*
 * Generated by desing-manual harness. Edit freely after initial capture.
 * Run: npm run test:vrt:update    # first capture / intentional changes
 *      npm run test:vrt           # regression check
 */

test.describe('${PROJECT} design baselines', () => {
  test.use({ viewport: { width: 1280, height: 800 } });

  test('light — viewport', async ({ page }) => {
    await page.goto('/');
    await page.evaluate(() => document.fonts?.ready);
    await expect(page).toHaveScreenshot('viewport-light.png');
  });

  test('dark — viewport', async ({ page }) => {
    await page.goto('/');
    await page.evaluate(() => { document.documentElement.dataset.theme = 'dark'; });
    await page.evaluate(() => document.fonts?.ready);
    await expect(page).toHaveScreenshot('viewport-dark.png');
  });

  test('light — full page', async ({ page }) => {
    await page.goto('/');
    await page.evaluate(() => document.fonts?.ready);
    await expect(page).toHaveScreenshot('full-light.png', { fullPage: true });
  });

  test('dark — full page', async ({ page }) => {
    await page.goto('/');
    await page.evaluate(() => { document.documentElement.dataset.theme = 'dark'; });
    await page.evaluate(() => document.fonts?.ready);
    await expect(page).toHaveScreenshot('full-dark.png', { fullPage: true });
  });

  test('a11y — first Tab lands on a focusable element', async ({ page }) => {
    await page.goto('/');
    await page.keyboard.press('Tab');
    const focused = await page.evaluate(() => document.activeElement?.tagName);
    expect(['A', 'BUTTON', 'INPUT', 'SELECT', 'TEXTAREA']).toContain(focused);
  });
});
